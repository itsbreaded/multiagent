{
  "extends": "@electron-toolkit/tsconfig/tsconfig.node.json",
  "include": [
    "electron.vite.config.*",
    "playwright.config.ts",
    "vitest.config.ts",
    "e2e/**/*",
    "src/main/**/*",
    "src/preload/**/*",
    "src/shared/**/*"
  ],
  "compilerOptions": {
    "composite": true,
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "types": [
      "electron-vite/node"
    ],
    "paths": {
      "@shared/*": ["./src/shared/*"]
    }
  }
}

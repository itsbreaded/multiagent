<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <!-- Required for the better-sqlite3 / node-pty native modules (neither is signed by
       Apple, so hardened-runtime library validation must be relaxed once signing is on). -->
  <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
  <true/>
  <key>com.apple.security.cs.disable-library-validation</key>
  <true/>
  <!-- better-sqlite3 needs JIT for its compiled query machinery. -->
  <key>com.apple.security.cs.allow-jit</key>
  <true/>
  <!-- Allow loading unsigned executable memory for node-pty's conpty/winpty deps if present. -->
  <key>com.apple.security.cs.allow-dyld-environment</key>
  <true/>
  <key>com.apple.security.network.client</key>
  <true/>
  <key>com.apple.security.network.server</key>
  <true/>
</dict>
</plist>
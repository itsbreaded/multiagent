{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "electron-vite: dev",
      "type": "shell",
      "command": "npm run dev",
      "isBackground": true,
      "problemMatcher": {
        "pattern": {
          "regexp": "^()$",
          "file": 1,
          "location": 2,
          "message": 3
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "^.*electron-vite.*$",
          "endsPattern": "^.*ready in.*$"
        }
      },
      "presentation": {
        "reveal": "silent",
        "panel": "dedicated",
        "group": "multiagent"
      }
    },
    {
      "label": "electron-vite: build",
      "type": "shell",
      "command": "npm run build",
      "problemMatcher": [],
      "presentation": {
        "reveal": "silent",
        "panel": "dedicated"
      }
    },
    {
      "label": "electron-vite: dev (inspect)",
      "type": "shell",
      "command": "npx electron-vite dev --inspect=9229",
      "isBackground": true,
      "problemMatcher": {
        "pattern": {
          "regexp": "^()$",
          "file": 1,
          "location": 2,
          "message": 3
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "^.*electron-vite.*$",
          "endsPattern": "^.*ready in.*$"
        }
      },
      "presentation": {
        "reveal": "silent",
        "panel": "dedicated",
        "group": "multiagent-debug"
      }
    }
  ]
}

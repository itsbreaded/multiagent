{
  "name": "multiagent",
  "version": "0.3.5",
  "description": "Multiagent",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "typecheck": "tsc -b --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "pack": "electron-builder --dir",
    "dist": "electron-vite build && electron-builder --win nsis dir",
    "dist:dir": "electron-vite build && electron-builder --win dir",
    "dist:nsis": "electron-vite build && electron-builder --win nsis",
    "release": "electron-vite build && electron-builder --win nsis --publish always",
    "postinstall": "node node_modules/electron/install.js && electron-rebuild -f -o better-sqlite3 && patch-package"
  },
  "keywords": [],
  "author": "Chris Haniszewski",
  "license": "MIT",
  "engines": {
    "node": ">=24 <25"
  },
  "devDependencies": {
    "@electron-toolkit/eslint-config-ts": "^3.0.0",
    "@electron-toolkit/tsconfig": "^2.0.0",
    "@electron/rebuild": "^4.0.4",
    "@tailwindcss/vite": "^4.3.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "@vitest/coverage-v8": "^4.1.9",
    "@xterm/addon-webgl": "^0.19.0",
    "electron": "^42.5.0",
    "electron-builder": "^26.15.3",
    "electron-vite": "^5.0.0",
    "happy-dom": "^18.0.1",
    "patch-package": "^8.0.1",
    "tailwindcss": "^4.3.1",
    "typescript": "^6.0.3",
    "vite": "^7.3.6",
    "vitest": "^4.1.9"
  },
  "dependencies": {
    "@electron-toolkit/preload": "^3.0.1",
    "@electron-toolkit/utils": "^4.0.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/xterm": "^6.0.0",
    "allotment": "^1.20.5",
    "better-sqlite3": "^12.11.1",
    "chokidar": "^5.0.0",
    "clsx": "^2.1.1",
    "electron-updater": "^6.8.9",
    "node-pty": "^1.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^3.6.0",
    "zustand": "^5.0.14"
  },
  "build": {
    "appId": "com.multiagent.app",
    "productName": "MultiAgent",
    "directories": {
      "buildResources": "build"
    },
    "files": [
      "out/**/*",
      "src/main/mcp/templates/**/*"
    ],
    "asarUnpack": [
      "**/*.node",
      "**/node-pty/**",
      "**/better-sqlite3/**"
    ],
    "npmRebuild": false,
    "publish": [
      {
        "provider": "github",
        "owner": "itsbreaded",
        "repo": "multiagent",
        "private": true,
        "releaseType": "release"
      }
    ],
    "win": {
      "target": [
        "nsis",
        "dir"
      ],
      "icon": "build/favicon.ico"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "allowToChangeInstallationDirectory": false
    },
    "mac": {
      "target": "dmg",
      "entitlementsInherit": "build/entitlements.mac.plist",
      "extendInfo": {
        "NSCameraUsageDescription": "Application requests access to the device's camera.",
        "NSMicrophoneUsageDescription": "Application requests access to the device's microphone.",
        "NSDocumentsFolderUsageDescription": "Application requests access to the user's Documents folder.",
        "NSDownloadsFolderUsageDescription": "Application requests access to the user's Downloads folder."
      }
    },
    "linux": {
      "target": "AppImage",
      "category": "Development"
    }
  }
}
